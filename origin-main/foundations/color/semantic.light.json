{
  "color": {
    "$type": "color",
    "surface": {
      "primary": { "$value": "{color.neutral.50}" },
      "secondary": { "$value": "{color.neutral.100}" },
      "tertiary": { "$value": "{color.neutral.200}" },
      "overlay": { "$value": "{color.neutral.50}" },
      "contrast": { "$value": "{color.neutral.1000}" }
    },
    "on-surface": {
      "primary": { "$value": "{color.neutral.1000}" },
      "secondary": { "$value": "{color.neutral.700}" },
      "tertiary": { "$value": "{color.neutral.500}" },
      "disabled": { "$value": "{color.neutral.400}" },
      "contrast": { "$value": "{color.neutral.50}" }
    },
    "border": {
      "primary": { "$value": "{color.neutral.200}" },
      "secondary": { "$value": "{color.neutral.300}" },
      "disabled": { "$value": "{color.neutral.200}" },
      "contrast": { "$value": "{color.neutral.1000}" }
    },
    "interactive": {
      "primary": { "$value": "{color.neutral.1000}" },
      "secondary": { "$value": "{color.neutral.100}" },
      "disabled": { "$value": "{color.neutral.200}" },
      "contrast": { "$value": "{color.neutral.50}" }
    },
    "error": {
      "solid": { "$value": "{color.red.600}" },
      "light": { "$value": "{color.red.100}" },
      "on-solid": { "$value": "{color.neutral.50}" },
      "on-light": { "$value": "{color.red.700}" },
      "border": { "$value": "{color.red.600}" }
    },
    "success": {
      "solid": { "$value": "{color.green.600}" },
      "light": { "$value": "{color.green.100}" },
      "on-solid": { "$value": "{color.neutral.50}" },
      "on-light": { "$value": "{color.green.700}" },
      "border": { "$value": "{color.green.600}" }
    },
    "warning": {
      "solid": { "$value": "{color.yellow.300}" },
      "light": { "$value": "{color.yellow.100}" },
      "on-solid": { "$value": "{color.neutral.1000}" },
      "on-light": { "$value": "{color.yellow.600}" },
      "border": { "$value": "{color.yellow.400}" }
    },
    "accent": {
      "solid": { "$value": "{color.blue.600}" },
      "light": { "$value": "{color.blue.100}" },
      "on-solid": { "$value": "{color.neutral.50}" },
      "on-light": { "$value": "{color.blue.700}" },
      "border": { "$value": "{color.blue.600}" }
    },
    "on-brand": {
      "light": { "$value": "{color.white-alpha.100}" },
      "light-secondary": { "$value": "{color.white-alpha.70}" },
      "light-disabled": { "$value": "{color.white-alpha.40}" },
      "dark": { "$value": "{color.black-alpha.100}" },
      "dark-secondary": { "$value": "{color.black-alpha.70}" },
      "dark-disabled": { "$value": "{color.black-alpha.40}" }
    },
    "overlay": {
      "scrim": { "$value": "{color.black-alpha.40}" },
      "solid-hover": { "$value": "{color.white-alpha.8}" },
      "solid-pressed": { "$value": "{color.white-alpha.16}" },
      "light-hover": { "$value": "{color.black-alpha.8}" },
      "light-pressed": { "$value": "{color.black-alpha.16}" }
    },
    "brand": {
      "maroon": { "$value": "{color.maroon.800}" },
      "crimson": { "$value": "{color.crimson.600}" },
      "teal": { "$value": "{color.teal.600}" },
      "blue": { "$value": "{color.blue.600}" },
      "peach": { "$value": "{color.peach.300}" },
      "gold": { "$value": "{color.gold.400}" },
      "lime": { "$value": "{color.lime.300}" }
    }
  }
}
