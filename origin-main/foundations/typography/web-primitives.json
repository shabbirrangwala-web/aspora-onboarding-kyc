    "lineHeight": {
      "$type": "number",
      "$description": "Web line heights as unitless ratios. Applied as CSS line-height multipliers. Mobile apps use primitives.json (fixed px).",
      "090": { "$value": 0.9 },
      "095": { "$value": 0.95 },
      "100": { "$value": 1 },
      "110": { "$value": 1.1 },
      "120": { "$value": 1.2 },
      "130": { "$value": 1.3 },
      "140": { "$value": 1.4 },
      "150": { "$value": 1.5 },
      "160": { "$value": 1.6 }
