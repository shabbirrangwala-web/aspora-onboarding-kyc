      "wide-1": { "$value": "0.5%" },
      "wide-2": { "$value": "1.5%" }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 },
      "heavy": { "$value": 900 }
    },
    "fontFamily": {
      "$type": "fontFamily",
      "primary": { "$value": "Haffer" },
      "mono": { "$value": "Haffer Mono" }
    }
  }
